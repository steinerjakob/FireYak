# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

def get_package_version_without_prerelease
  # Load package.json
  package = load_json(json_path: "./package.json")

  # Get version and strip prerelease information
  version = package["version"]

  # Remove prerelease information (everything after the first hyphen)
  # This handles cases like "1.2.3-beta.1" -> "1.2.3"
  clean_version = version.split('-')[0]

  return clean_version
end

platform :android do
  desc "Runs all the tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Submit a new Beta Build to Crashlytics Beta"
  lane :beta do
    gradle(task: "clean assembleRelease")
    crashlytics

    # sh "your_script.sh"
    # You can also use other beta testing services here
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do
    gradle(task: "clean assembleRelease")
    upload_to_play_store
  end

  desc "Upload metadata to Google Play (no binary)"
  lane :upload_metadata do
    upload_to_play_store(
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: false,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      skip_upload_metadata: false
    )
  end
end

platform :ios do 

  private_lane :default_ios_app_build do |options|
    setup_ci
    ios_dir = File.expand_path('../ios')

    increment_version_number(
      version_number: get_package_version_without_prerelease,
      xcodeproj: File.join(ios_dir, "App/App.xcodeproj")
    )

    match(type: "appstore", readonly: is_ci, api_key_path: "./authkey.json")

		build_app(project: File.join(ios_dir, "App/App.xcodeproj"), scheme: "App")

  end

  lane :beta do |options|
    desc "Push a new build to TestFlight"
    default_ios_app_build(options)
		pilot(
				skip_waiting_for_build_processing: true,
        api_key_path: "./authkey.json"
		)
  end

  desc "Upload metadata to App Store Connect (no binary)"
  lane :upload_metadata do
    deliver(
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      force: true,
      metadata_path: "./fastlane/metadata/ios",
      api_key_path: "./authkey.json"
    )
  end
end
